---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
}

const { 
  title, 
  description = "Calculate your overtime pay instantly. Enter hourly rate + overtime hours — see overtime earnings, rate per hour, regular pay, and total weekly gross. Free. No sign-up. Any device.",
  canonical = "https://overtimecal.com/"
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta name="twitter:card" content="summary" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" href="/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  
  <!-- Anti-flash: apply saved theme before first paint -->
  <script is:inline>
    (function(){
      var t=localStorage.getItem('oc-theme');
      if(t) document.documentElement.setAttribute('data-theme',t);
      else if(window.matchMedia('(prefers-color-scheme: dark)').matches) document.documentElement.setAttribute('data-theme','dark');
      else document.documentElement.setAttribute('data-theme','light');
    })()
  </script>
  
  <script type="application/ld+json">
    {"@context":"https://schema.org","@type":"WebApplication","name":"OvertimeCal","url":"https://overtimecal.com","description":"Free overtime pay calculator. Instantly calculate overtime pay, overtime rate, and total weekly earnings.","applicationCategory":"FinanceApplication","operatingSystem":"Any","offers":{"@type":"Offer","price":"0","priceCurrency":"USD"}}
  </script>
  <script type="application/ld+json">
    {"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"How do you calculate overtime pay?","acceptedAnswer":{"@type":"Answer","text":"Overtime pay = hourly rate × multiplier × overtime hours. Time and a half: $15 × 1.5 × 8 hrs = $180."}},{"@type":"Question","name":"What is time and a half?","acceptedAnswer":{"@type":"Answer","text":"Time and a half is 1.5× your regular hourly rate. US federal law requires this after 40 hours per workweek."}},{"@type":"Question","name":"When does overtime start?","acceptedAnswer":{"@type":"Answer","text":"Federal: after 40 hrs/week. California and Alaska: after 8 hrs/day. Colorado: after 12 hrs/day."}},{"@type":"Question","name":"Is overtime taxed more?","acceptedAnswer":{"@type":"Answer","text":"No. Overtime is taxed at the same rates as regular income."}},{"@type":"Question","name":"Do salaried employees get overtime?","acceptedAnswer":{"@type":"Answer","text":"Yes, if they earn under $684/week ($35,568/year)."}},{"@type":"Question","name":"What is double time?","acceptedAnswer":{"@type":"Answer","text":"Double time is 2× your regular rate. California requires it after 12 hours in a single workday."}}]}
  </script>
</head>
<body>
  <slot />
  <script is:inline>
    // Clean up and completely disable any active Service Workers
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.getRegistrations().then(registrations => {
        if (registrations.length > 0) {
          Promise.all(registrations.map(r => r.unregister())).then(() => {
            console.log('Cleared Service Worker.');
            window.location.reload();
          });
        }
      });
    }
  </script>
</body>
</html>
