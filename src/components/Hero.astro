---
import Calculator from './Calculator.astro';
---
<section class="relative overflow-hidden py-10 lg:py-16 border-b border-b1">
  <!-- Subtle radial glow (dark only) -->
  <div class="hidden dark:block absolute inset-0 bg-[radial-gradient(ellipse_70%_40%_at_50%_0%,rgba(129,140,248,0.08),transparent_70%)] pointer-events-none"></div>
  
  <div class="wrap relative z-10">
    <div class="grid md:grid-cols-[1fr_440px] lg:grid-cols-[1fr_580px] gap-8 lg:gap-16 items-start">
      <div class="hero-text lg:pr-8 lg:pt-3">
        
        <h1 class="text-4xl lg:text-[60px] font-extrabold tracking-tight leading-[1.05] text-t1 mb-5">
          Calculate your <br/><span class="text-green">overtime pay</span>
        </h1>
        <p class="text-base lg:text-lg text-t2 max-w-lg leading-relaxed mb-6 font-medium opacity-90">
          Enter your hourly rate and overtime hours. Get your exact overtime earnings, rate per hour, and total weekly gross — instantly.
        </p>

        <!-- Feature list to fill vertical space -->
        <div class="mt-8 flex flex-col gap-4 border-t border-b1 pt-6 max-w-md">
          <span class="text-[10px] font-bold text-t3 uppercase tracking-[0.1em]">Features</span>
          <div class="flex items-center gap-3 text-[13.5px] font-medium text-t2">
            <div class="w-5 h-5 rounded-full bg-green-dim flex items-center justify-center shrink-0">
              <svg class="text-green w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="4"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <span>FLSA & state laws (CA daily OT, Alaska daily OT, NV, CO)</span>
          </div>
          <div class="flex items-center gap-3 text-[13.5px] font-medium text-t2">
            <div class="w-5 h-5 rounded-full bg-green-dim flex items-center justify-center shrink-0">
              <svg class="text-green w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="4"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <span>Time & Half (1.5x), Double Time (2x) & Custom multipliers</span>
          </div>
          <div class="flex items-center gap-3 text-[13.5px] font-medium text-t2">
            <div class="w-5 h-5 rounded-full bg-green-dim flex items-center justify-center shrink-0">
              <svg class="text-green w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="4"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <span>Printable PDF report exports and clipboard copy</span>
          </div>
        </div>
      </div>

      <div class="justify-self-center lg:justify-self-end w-full max-w-none md:max-w-[440px] lg:max-w-[580px]">
        <Calculator />
      </div>
    </div>
  </div>
</section>
