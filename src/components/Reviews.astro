---
const testimonials = [
  { 
    name: 'Jordan S.', 
    role: 'Warehouse Associate', 
    content: '"California overtime rules are so confusing. This tool made it instant to see exactly what I was owed after a long week. Spot on accuracy."',
    bg: '#fb923c',
    initials: 'JS'
  },
  { 
    name: 'Maria A.', 
    role: 'Registered Nurse', 
    content: '"I use this every Sunday before submitting my timesheet. The interface is clean and works perfectly on my phone while I\'m on the go."',
    bg: '#8b5cf6',
    initials: 'MA'
  },
  { 
    name: 'David K.', 
    role: 'Retail Manager', 
    content: '"The Print and Copy features are game changers for keeping records. It\'s rare to find a tool this good that doesn\'t require a sign-up."',
    bg: '#34d399',
    initials: 'DK'
  }
];
---
<section class="py-24 border-b border-b1" id="testimonials">
  <div class="max-w-[1200px] mx-auto px-5 md:px-10">
    <span class="inline-block text-[11px] font-bold tracking-[0.1em] uppercase text-accent mb-2.5">Social proof</span>
    <h2 class="text-3xl md:text-4xl font-semibold tracking-tight text-t1 leading-[1.15] mb-3">Trusted by hourly workers</h2>
    <p class="text-[15px] text-t2 max-w-[600px] leading-[1.7] mb-10">Join thousands of employees across the US who use OvertimeCal to ensure their paychecks are accurate.</p>
 
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-10">
      {testimonials.map((t) => (
        <div class="bg-s1 border border-b1 rounded-xl p-8 hover:-translate-y-1 hover:shadow-lg transition-all duration-200 group">
          <div class="flex gap-0.5 text-[#fb923c] mb-3 transition-transform group-hover:scale-105 origin-left">
            {[...Array(5)].map(() => (
              <svg viewBox="0 0 20 20" class="w-3.5 h-3.5 fill-current"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            ))}
          </div>
          <div class="flex items-center gap-3 mb-5">
            <div class="w-9 h-9 rounded-full flex items-center justify-center font-semibold text-white text-[13px] shrink-0" style={`background:${t.bg}`}>{t.initials}</div>
            <div>
              <h4 class="text-sm font-semibold text-t1">{t.name}</h4>
              <p class="text-xs text-t3">{t.role}</p>
            </div>
          </div>
          <p class="text-[14.5px] text-t2 leading-relaxed italic">{t.content}</p>
        </div>
      ))}
    </div>
  </div>
</section>
