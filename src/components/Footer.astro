<footer class="bg-[#101010] border-t border-[#1A1A1A] py-16 text-[#A1A1AA]">
  <div class="max-w-[1200px] mx-auto px-5 md:px-10">
    <div class="flex flex-col md:flex-row justify-between gap-10 items-start">
      <div class="max-w-[300px]">
        <a class="flex items-center gap-3 no-underline mb-4 group" href="/" aria-label="OvertimeCal">
          <div class="w-[30px] h-[30px] bg-[#27272A] rounded-lg flex items-center justify-center shrink-0 transition-colors group-hover:bg-[#3F3F46]">
            <svg viewBox="0 0 18 18" fill="none" aria-hidden="true" class="w-4 h-4">
              <circle cx="9" cy="9" r="7.5" stroke="white" stroke-width="1.5"/>
              <path d="M9 5v4l2.5 2.5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <span class="text-[15px] font-bold text-white tracking-tight">OvertimeCal</span>
        </a>
        <p class="text-xs leading-relaxed mb-4">Free, high-fidelity overtime pay calculator built for hourly workers. Estimates only — consult an employment attorney for specific guidance.</p>
        <div class="text-[11px] opacity-50">© 2026 OvertimeCal. All rights reserved.</div>
      </div>
      <div class="flex-1 grid grid-cols-2 gap-10">
        <div>
          <div class="text-[11px] font-bold uppercase tracking-wider text-white mb-4">Product</div>
          <nav class="flex flex-col gap-2.5">
            <a href="/calculator" class="text-[13px] no-underline hover:text-white transition-colors font-bold text-green">Detailed Calculator</a>
            <a href="/#calculator" class="text-[13px] text-inherit no-underline hover:text-white transition-colors">Simple Calculator</a>
            <a href="/#rate-chart" class="text-[13px] text-inherit no-underline hover:text-white transition-colors">Rate Chart</a>
            <a href="/#how-it-works" class="text-[13px] text-inherit no-underline hover:text-white transition-colors">How it Works</a>
          </nav>
        </div>
        <div>
          <div class="text-[11px] font-bold uppercase tracking-wider text-white mb-4">Resources</div>
          <nav class="flex flex-col gap-2.5">
            <a href="/about" class="text-[13px] text-inherit no-underline hover:text-white transition-colors">About Us</a>
            <a href="/#faq" class="text-[13px] text-inherit no-underline hover:text-white transition-colors">FAQ</a>
            <a href="/#states" class="text-[13px] text-inherit no-underline hover:text-white transition-colors">State Laws</a>
            <a href="/privacy-policy" class="text-[13px] text-inherit no-underline hover:text-white transition-colors">Privacy Policy</a>
            <a href="/terms-conditions" class="text-[13px] text-inherit no-underline hover:text-white transition-colors">Terms & Conditions</a>
          </nav>
        </div>
      </div>
    </div>
  </div>
</footer>
