---
const faqs = [
  {
    question: "How do I calculate overtime pay?",
    answer:
      "Multiply your regular hourly rate by 1.5 for every hour worked over 40 in a workweek. For example, at $20/hr your overtime rate is $30/hr. Our calculator does this automatically — just enter your hourly rate and total hours worked.",
  },
  {
    question: "Is there no tax on overtime in 2025?",
    answer:
      "Overtime is still taxed under current federal law. However, there is active legislation proposing to exempt overtime pay from federal income tax. We'll update this calculator the moment that changes. Use the 'with taxes' toggle to see your estimated take-home either way.",
  },
  {
    question: "Is overtime taxed more than regular pay?",
    answer:
      "Not exactly. Overtime is taxed at the same marginal rates as regular income — but because it pushes your total earnings higher, more of your income may fall into a higher bracket. Your effective tax rate on overtime is usually only a few percent higher than on regular pay.",
  },
  {
    question: "Is overtime worth it after taxes?",
    answer:
      "Almost always yes. Even in a higher tax bracket, you keep a meaningful portion of every overtime dollar. For example, in the 22% federal bracket you take home roughly $1.17 for every overtime dollar earned above your regular rate. Our calculator shows your exact net gain.",
  },
  {
    question: "What are the overtime rules in California?",
    answer:
      "California has daily overtime rules that go beyond federal law. You earn 1.5× pay for hours over 8 in a single day, 2× pay for hours over 12 in a day, and 1.5× for the first 8 hours on the 7th consecutive workday. The weekly 40-hour federal rule also applies — whichever triggers first.",
  },
  {
    question: "What are the overtime rules in Texas?",
    answer:
      "Texas follows federal FLSA rules — 1.5× pay for any hours over 40 in a workweek. Texas has no state income tax, so your overtime take-home is higher compared to most other states.",
  },
  {
    question: "Do salaried employees get overtime?",
    answer:
      "Salaried employees earning under $684/week ($35,568/year) are entitled to overtime under the FLSA. Above that threshold, it depends on your job duties. Many managers and professionals are exempt, but the salary level alone doesn't automatically exempt you.",
  },
  {
    question: "When does overtime start?",
    answer:
      "Under federal law, overtime begins after 40 hours in a single workweek. Some states like California also have daily overtime — it starts after 8 hours in a single day, regardless of your weekly total.",
  },
  {
    question: "What is time and a half?",
    answer:
      "Time and a half means you earn 1.5× your regular hourly rate. If you make $18/hr, your time-and-a-half rate is $27/hr. This is the standard overtime rate required by federal law for most employees.",
  },
  {
    question: "What is double time pay?",
    answer:
      "Double time means 2× your regular hourly rate. Federal law doesn't require it, but California mandates double time for hours over 12 in a workday or for the first 8 hours on the 7th consecutive day of a workweek.",
  },
  {
    question: "Does PTO count toward overtime?",
    answer:
      "No. Under federal law, only actual hours worked count toward the 40-hour overtime threshold. If you took 8 hours of PTO and worked 36 hours, you worked 36 hours — not 44 — so no overtime is owed.",
  },
  {
    question: "What if my employer doesn't pay overtime?",
    answer:
      "You can file a wage complaint with the U.S. Department of Labor's Wage and Hour Division. You may be entitled to back pay for up to 2 years (3 years if the violation was willful), plus an equal amount in liquidated damages.",
  },
];
---
<section class="py-24 bg-s1 border-b border-b1" id="faq">
  <div class="max-w-[1200px] mx-auto px-5 md:px-10">
    <span class="inline-block text-[11px] font-bold tracking-[0.1em] uppercase text-accent mb-2.5">FAQ</span>
    <h2 class="text-3xl md:text-4xl font-semibold tracking-tight text-t1 leading-[1.15] mb-3">Common questions</h2>
    <p class="text-[15px] text-t2 max-w-[600px] leading-[1.7] mb-10">Everything you need to know about overtime pay how it's calculated, when it applies, and what your employer is required to pay.</p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-b1 border border-b1 rounded-xl overflow-hidden shadow-sm">
      {faqs.map((faq) => (
        <details name="faq" class="bg-s1 group transition-all duration-200">
          <summary class="p-5 text-sm font-semibold text-t1 cursor-pointer list-none flex justify-between items-start gap-3 select-none hover:text-accent group-open:text-accent group-open:border-b group-open:border-b1 leading-snug">
            {faq.question}
            <svg class="w-[18px] h-[18px] shrink-0 text-t3 transition-transform duration-200 group-open:rotate-45" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
          </summary>
          <div class="p-5 pt-3.5 pb-4.5 text-[13.5px] text-t2 leading-relaxed" set:html={faq.answer}></div>
        </details>
      ))}
    </div>
  </div>
</section>

<script>
  // Fallback for browsers that don't support the `name` attribute on `<details>`
  document.addEventListener('DOMContentLoaded', () => {
    const detailsElements = document.querySelectorAll('#faq details');
    detailsElements.forEach((targetDetail) => {
      targetDetail.addEventListener('toggle', () => {
        if (targetDetail.open) {
          detailsElements.forEach((detail) => {
            if (detail !== targetDetail && detail.open) {
              detail.removeAttribute('open');
            }
          });
        }
      });
    });
  });
</script>
