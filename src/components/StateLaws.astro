---
const states = [
  { name: 'Federal (FLSA)', type: 'Default', weekly: '40 hrs/week', daily: '—', rate: '1.5×', notes: 'Covers most US employees' },
  { name: 'California', type: 'Special', weekly: '40 hrs/week', daily: '8 hrs/day', rate: '1.5×; 2× after 12 hrs', notes: 'Strictest in the US. Double time after 12 hrs/day or 8 hrs on 7th day' },
  { name: 'Alaska', type: 'Special', weekly: '40 hrs/week', daily: '8 hrs/day', rate: '1.5×', notes: 'Daily OT after 8 hrs; no double time requirement' },
  { name: 'Colorado', type: 'Special', weekly: '40 hrs/week', daily: '12 hrs/day', rate: '1.5×', notes: 'Daily OT after 12 hrs in a workday' },
  { name: 'Nevada', type: 'Special', weekly: '40 hrs/week', daily: '8 hrs/day (conditional)', rate: '1.5×', notes: 'Daily OT only if earning ≤ 1.5× Nevada minimum wage' },
  { name: 'New York', type: '', weekly: '40 hrs/week', daily: '—', rate: '1.5×', notes: 'Follows federal; higher state minimum wage' },
  { name: 'Texas', type: '', weekly: '40 hrs/week', daily: '—', rate: '1.5×', notes: 'Follows federal FLSA exactly' },
  { name: 'Florida', type: '', weekly: '40 hrs/week', daily: '—', rate: '1.5×', notes: 'Follows federal FLSA exactly' },
  { name: 'Washington', type: '', weekly: '40 hrs/week', daily: '—', rate: '1.5×', notes: 'Follows federal; $16.28/hr minimum wage (2024)' },
  { name: 'All other states (38)', type: '', weekly: '40 hrs/week', daily: '—', rate: '1.5×', notes: 'Default to federal FLSA rules' },
];
---
<section class="py-24 bg-s1 border-b border-b1" id="states">
  <div class="max-w-[1200px] mx-auto px-5 md:px-10">
    <span class="inline-block text-[11px] font-bold tracking-[0.1em] uppercase text-accent mb-2.5">By state</span>
    <h2 class="text-3xl md:text-4xl font-semibold tracking-tight text-t1 leading-[1.15] mb-3">Overtime laws by state</h2>
    <p class="text-[15px] text-t2 max-w-[600px] leading-[1.7] mb-10">Most states follow the federal 40 hrs/week rule. A handful have daily overtime thresholds that can kick in before you hit 40 hours for the week.</p>
    
    <div class="overflow-x-auto border border-b1 rounded-xl bg-bg shadow-sm">
      <table class="w-full border-collapse min-w-[700px]">
        <thead>
          <tr class="bg-s2 border-b border-b1">
            <th class="px-5 py-3.5 text-[11px] font-bold text-t3 uppercase tracking-wider text-left">State</th>
            <th class="px-5 py-3.5 text-[11px] font-bold text-t3 uppercase tracking-wider text-left">Weekly threshold</th>
            <th class="px-5 py-3.5 text-[11px] font-bold text-t3 uppercase tracking-wider text-left">Daily threshold</th>
            <th class="px-5 py-3.5 text-[11px] font-bold text-t3 uppercase tracking-wider text-left">OT rate</th>
            <th class="px-5 py-3.5 text-[11px] font-bold text-t3 uppercase tracking-wider text-left">Notes</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-b1">
          {states.map((s) => (
            <tr class="hover:bg-s2 transition-colors">
              <td class="px-5 py-3.5 text-sm font-semibold text-t1">
                <div class="flex items-center gap-2">
                  {s.name}
                  {s.type === 'Default' && <span class="text-[10px] font-bold px-1.5 py-0.5 rounded-full bg-[#EEF2FF] text-[#4F46E5] border border-[#C7D2FE] dark:bg-[#1E1B4B] dark:text-[#60A5FA] dark:border-[#1E1B4B]">Default</span>}
                  {s.type === 'Special' && <span class="text-[10px] font-bold px-1.5 py-0.5 rounded-full bg-[#FFF7ED] text-[#B45309] border border-[#FDE68A] dark:bg-[#1C0A00] dark:text-[#FCD34D] dark:border-[#1C0A00]">Special</span>}
                </div>
              </td>
              <td class="px-5 py-3.5 text-sm text-t2">{s.weekly}</td>
              <td class="px-5 py-3.5 text-sm text-t2">{s.daily}</td>
              <td class="px-5 py-3.5 text-sm text-t2 font-medium">{s.rate}</td>
              <td class="px-5 py-3.5 text-xs text-t3 leading-normal">{s.notes}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>
