---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout 
  title="Page Not Found — 404 Error"
  description="The page you are looking for does not exist."
>
  <Header />

  <main class="min-h-screen bg-bg flex flex-col justify-center py-20">
    <div class="wrap text-center max-w-2xl mx-auto flex-1 flex flex-col items-center justify-center">
      <h1 class="text-6xl sm:text-9xl font-extrabold text-t1 mb-6 tracking-tight">404</h1>
      <h2 class="text-3xl sm:text-4xl font-bold text-t1 mb-4">Page Not Found</h2>
      <p class="text-base sm:text-lg text-t2 font-medium opacity-90 leading-relaxed mb-10 max-w-md">
        Sorry, we couldn't find the page you're looking for. It might have been moved or no longer exists.
      </p>
      <a href="/" class="inline-flex items-center justify-center h-[52px] px-8 bg-green hover:bg-green/90 text-bg font-bold rounded-xl transition-all shadow-[0_4px_0_0_rgba(20,20,20,1)] hover:shadow-[0_2px_0_0_rgba(20,20,20,1)] hover:translate-y-[2px]">
        Return Home
      </a>
    </div>
  </main>

  <Footer />
</Layout>
