---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import HowItWorks from '../components/HowItWorks.astro';
import RateChart from '../components/RateChart.astro';
import StateLaws from '../components/StateLaws.astro';
import Reviews from '../components/Reviews.astro';
import FAQ from '../components/FAQ.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
---

<Layout 
  title="Free Overtime Calculator — Calculate Overtime Pay Instantly"
  description="Use our free overtime pay calculator to determine your earnings. Features a no tax on overtime calculator, California overtime rules, and customized hourly breakdown."
>
  <Header />

  <main>
    <Hero />
    <HowItWorks />
    <RateChart />
    <StateLaws />
    <Reviews />
    <FAQ />
    <CTA />
  </main>

  <Footer />
</Layout>
