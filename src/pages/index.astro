  <script is:inline>
    /* ── Theme toggle ───────────────── */
    const html      = document.documentElement;
    const toggleBtn = document.getElementById('theme-toggle');

    const SUN  = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>`;
    const MOON = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>`;

    function applyTheme(t) {
      html.setAttribute('data-theme', t);
      localStorage.setItem('oc-theme', t);
      toggleBtn.innerHTML = t === 'dark' ? SUN : MOON;
      toggleBtn.title = t === 'dark' ? 'Switch to light mode' : 'Switch to dark mode';
    }

    toggleBtn.addEventListener('click', () => {
      applyTheme(html.dataset.theme === 'dark' ? 'light' : 'dark');
    });

    // Init icon (theme already applied by inline head script)
    applyTheme(html.dataset.theme || 'dark');

    /* ── Calculator ─────────────────── */
    const rateEl      = document.getElementById('hourly-rate');
    const hoursEl     = document.getElementById('ot-hours');
    const banner      = document.getElementById('state-banner');
    const multHint    = document.getElementById('mult-hint');
    const infoTitle   = document.getElementById('state-info-title');
    const infoText    = document.getElementById('state-info-text');
    const otPayEl     = document.getElementById('ot-pay');
    const otRateSubEl = document.getElementById('ot-rate-sub');
    const otRateCard  = document.getElementById('ot-rate-card');
    const regPayEl    = document.getElementById('reg-pay');
    const totPayEl    = document.getElementById('total-pay');
    const multBtns    = document.querySelectorAll('.mult-btn');
    const allStateEls = [
      document.getElementById('state-select-top'),
      document.getElementById('state-select-col'),
    ];

    let mult = 1.5;

    const STATES = {
      federal: { hint:'US federal FLSA: 1.5× applies after 40 hours per workweek for most employees', title:'Federal (FLSA):', text:'Overtime at 1.5× applies after 40 hours per workweek. Baseline rule for most US employees under the Fair Labor Standards Act.', banner:null },
      ca:      { hint:'California: 1.5× after 8 hrs/day or 40 hrs/week · 2× after 12 hrs/day', title:'California:', text:'1.5× after 8 hours/day or 40 hours/week. Double time (2×) required after 12 hours in a day, or after 8 hours on the 7th consecutive workday.', banner:'<strong>California daily OT applies.</strong> Overtime starts after 8 hrs/day — even without hitting 40 hrs/week. Select 2× if you\'ve worked 12+ hours in a single day.' },
      nv:      { hint:'Nevada: 1.5× after 8 hrs/day (conditional) or 40 hrs/week', title:'Nevada:', text:'1.5× after 8 hours/day for employees earning ≤ 1.5× Nevada minimum wage, or after 40 hours/week for all employees.', banner:null },
      ak:      { hint:'Alaska: 1.5× after 8 hrs/day or 40 hrs/week — whichever comes first', title:'Alaska:', text:'1.5× after 8 hours in a single workday or after 40 hours/week — whichever comes first.', banner:'<strong>Alaska daily OT applies.</strong> Overtime kicks in after 8 hours in a workday, even without 40 total hours for the week.' },
      co:      { hint:'Colorado: 1.5× after 12 hrs/day or 40 hrs/week', title:'Colorado:', text:'1.5× after 12 hours in a single workday or after 40 hours/week — whichever results in more OT pay.', banner:null },
      ny:      { hint:'New York: 1.5× after 40 hrs/week (follows federal FLSA)', title:'New York:', text:'Follows federal FLSA: 1.5× for all hours beyond 40 per workweek. Higher state minimum wage than federal.', banner:null },
      tx:      { hint:'Texas: 1.5× after 40 hrs/week (follows federal FLSA)', title:'Texas:', text:'Follows federal FLSA exactly: 1.5× for hours beyond 40 per workweek. No additional state overtime provisions.', banner:null },
      fl:      { hint:'Florida: 1.5× after 40 hrs/week (follows federal FLSA)', title:'Florida:', text:'Follows federal FLSA exactly: 1.5× for hours beyond 40 per workweek. No additional state overtime provisions.', banner:null },
      wa:      { hint:'Washington: 1.5× after 40 hrs/week', title:'Washington:', text:'Follows federal FLSA: 1.5× after 40 hours/week. Washington has a high state minimum wage ($16.28/hr in 2024).', banner:null },
      il:      { hint:'Illinois: 1.5× after 40 hrs/week', title:'Illinois:', text:'Follows federal FLSA: 1.5× after 40 hours/week, enforced by the Illinois Department of Labor.', banner:null },
      oh:      { hint:'Ohio: 1.5× after 40 hrs/week (follows federal FLSA)', title:'Ohio:', text:'Follows federal FLSA: 1.5× after 40 hours/week. No additional state overtime provisions.', banner:null },
    };

    function fmt(n) {
      return '$' + n.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
    }

    function calc() {
      const rate    = Math.max(0, parseFloat(rateEl.value)  || 0);
      const otHours = Math.max(0, parseFloat(hoursEl.value) || 0);
      const otRate  = rate * mult;
      const otPay   = otHours * otRate;
      const regPay  = 40 * rate;
      const total   = regPay + otPay;
      otPayEl.textContent    = fmt(otPay);
      otRateSubEl.textContent= 'at $' + otRate.toFixed(2) + '/hr OT rate';
      otRateCard.textContent = '$' + otRate.toFixed(2);
      regPayEl.textContent   = fmt(regPay);
      totPayEl.textContent   = fmt(total);
    }

    function updateState(value) {
      const s = STATES[value] || STATES.federal;
      multHint.textContent  = s.hint;
      infoTitle.textContent = s.title;
      infoText.textContent  = s.text;
      banner.innerHTML      = s.banner || '';
      banner.hidden         = !s.banner;
      allStateEls.forEach(el => { if (el) el.value = value; });
    }

    allStateEls.forEach(el => {
      if (el) el.addEventListener('change', e => updateState(e.target.value));
    });

    rateEl.addEventListener('input', calc);
    hoursEl.addEventListener('input', calc);

    multBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        multBtns.forEach(b => { b.classList.remove('active'); b.setAttribute('aria-pressed', 'false'); });
        btn.classList.add('active');
        btn.setAttribute('aria-pressed', 'true');
        mult = parseFloat(btn.dataset.mult);
        calc();
      });
    });
  </script>

</body>
</html>
