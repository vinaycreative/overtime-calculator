    .faq-item[open] > summary { color: var(--accent); border-bottom: 1px solid var(--b1); }

    .faq-body { padding: 14px 20px 18px; font-size: 13.5px; color: var(--t2); line-height: 1.75; }
    .faq-body strong { color: var(--t1); }

    /* ── Footer ──────────────────────── */
    .site-footer { border-top: 1px solid var(--b1); padding: 32px 0; }

