    tbody tr { border-bottom: 1px solid var(--b1); }
    tbody tr:last-child { border-bottom: none; }
    tbody tr:hover { background: var(--s2); }

    tbody td { padding: 11px 16px; font-size: 13.5px; color: var(--t2); font-variant-numeric: tabular-nums; }
    tbody td:first-child { font-weight: 600; color: var(--t1); }
    tbody td:not(:first-child) { text-align: right; }

    .td-green { color: var(--green) !important; font-weight: 700; }
    .td-accent { color: var(--accent) !important; font-weight: 700; }

    .pill {
      display: inline-block;
      font-size: 10.5px;
      font-weight: 700;
      padding: 2px 7px;
      border-radius: 100px;
      letter-spacing: 0.02em;
      white-space: nowrap;
    }

    .pill-amber { background: rgba(252,211,77,0.1); color: #FCD34D; border: 1px solid rgba(252,211,77,0.2); }
    .pill-blue  { background: rgba(129,140,248,0.1); color: var(--accent); border: 1px solid rgba(129,140,248,0.2); }

    [data-theme="light"] .pill-amber { background: #FFF7ED; color: #B45309; border-color: #FDE68A; }
    [data-theme="light"] .pill-blue  { background: #EEF2FF; color: #4F46E5; border-color: #C7D2FE; }

    .state-tbl td:not(:first-child) { text-align: left; }

    /* ── FAQ ─────────────────────────── */
    .faq-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1px;
      background: var(--b1);
      border: 1px solid var(--b1);
      border-radius: 10px;
      overflow: hidden;
    }

    @media (min-width: 768px) { .faq-grid { grid-template-columns: 1fr 1fr; } }

    .faq-item { background: var(--s1); }

    .faq-item summary {
      padding: 16px 20px;
      font-size: 14px;
      font-weight: 600;
      color: var(--t1);
      cursor: pointer;
      list-style: none;
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 12px;
      user-select: none;
      -webkit-tap-highlight-color: transparent;
      line-height: 1.4;
    }

